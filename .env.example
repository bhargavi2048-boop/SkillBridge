# SkillBridge Environment Configuration
# Copy this to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/skillbridge

# JWT
JWT_SECRET=your_very_secure_jwt_secret_change_this_in_production
JWT_EXPIRES_IN=7d

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=SkillBridge <noreply@skillbridge.io>

# Anthropic Claude AI
ANTHROPIC_API_KEY=your_anthropic_api_key

# Google Meet / Calendar (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Redis (Optional - for session caching)
REDIS_URL=redis://localhost:6379

# Admin credentials
ADMIN_EMAIL=admin@skillbridge.io
ADMIN_SECRET=your_admin_secret

# File Upload
MAX_FILE_SIZE=5mb
UPLOAD_DIR=./uploads

# Twilio (Optional - SMS reminders)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE=+1234567890
